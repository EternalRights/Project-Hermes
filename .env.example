# ============================================================
# Project Hermes - Environment Configuration Template
# Copy this file to .env and modify values as needed
# ============================================================

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-secure-random-string
JWT_SECRET_KEY=change-me-to-a-secure-jwt-secret-string

# Database
DATABASE_URL=mysql+pymysql://hermes:hermes123@mysql:3306/hermes

# Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# MySQL (for docker-compose)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=hermes
MYSQL_USER=hermes
MYSQL_PASSWORD=hermes123

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_WORKERS=4
SERVER_TIMEOUT=120

# Worker
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=100
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Nginx
NGINX_WORKER_PROCESSES=4
